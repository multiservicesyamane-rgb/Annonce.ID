# Copie ce fichier en .env.local et remplis les valeurs.

# Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# SMS OTP — Africa's Talking (laisser vide = mode démo, code 1234)
AFRICASTALKING_API_KEY=xxx
AFRICASTALKING_USERNAME=xxx

# Paiement mobile money — CinetPay
CINETPAY_API_KEY=xxx
CINETPAY_SITE_ID=xxx

# Images — Cloudinary (optionnel)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# Admin /yamanetech
ADMIN_EMAIL=admin@yamanetech.com
ADMIN_PASSWORD_HASH=bcrypt_hash_ici
ADMIN_2FA_SECRET=xxx

# App
NEXT_PUBLIC_APP_URL=https://annonce.id
