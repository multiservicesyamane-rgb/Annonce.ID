# Copie ce fichier en .env.local et remplis les valeurs.

# Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# SMS OTP — Africa's Talking (laisser vide = mode démo, code 1234)
AFRICASTALKING_API_KEY=xxx
AFRICASTALKING_USERNAME=xxx

# Paiement mobile money — CinetPay
CINETPAY_API_KEY=xxx
CINETPAY_SITE_ID=xxx

# Images — Cloudinary (optionnel)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# Assistant IA — Claude (Anthropic). Clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxx

# PayTech (paiement)
PAYTECH_API_KEY=xxx
PAYTECH_API_SECRET=xxx

# Admin /yamanetech
ADMIN_EMAIL=admin@yamanetech.com
ADMIN_PASSWORD_HASH=bcrypt_hash_ici
ADMIN_2FA_SECRET=xxx

# ─────────────────────────────────────────────────────────────
# PUBLICATION AUTOMATIQUE RÉSEAUX SOCIAUX (gratuit, natif Next.js)
# ─────────────────────────────────────────────────────────────

# IA Gemini 1.5 Flash (gratuit) — https://aistudio.google.com/app/apikey
# Vide = repli automatique sur des textes templates (toujours fonctionnel).
GEMINI_API_KEY=xxx

# Telegram (100% gratuit) — bot via @BotFather, mettre le bot admin du canal.
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_CHANNEL_ID=@moncanal

# Facebook Page (Graph API gratuite)
META_PAGE_ID=xxx
META_ACCESS_TOKEN=xxx

# WhatsApp Business Cloud API + reponse IA automatique
# Webhook Meta: https://ton-domaine.com/api/whatsapp/webhook
WHATSAPP_AI_ENABLED=false
WHATSAPP_VERIFY_TOKEN=change-moi-whatsapp
WHATSAPP_ACCESS_TOKEN=xxx
WHATSAPP_PHONE_NUMBER_ID=xxx
WHATSAPP_APP_SECRET=xxx
WHATSAPP_GRAPH_VERSION=v20.0

# Sécurité du cron + déclenchement manuel
# CRON_SECRET : injecté par Vercel dans l'en-tête Authorization du cron.
CRON_SECRET=change-moi
# CAMPAIGN_WEBHOOK_SECRET : header x-campaign-secret pour déclenchement manuel.
CAMPAIGN_WEBHOOK_SECRET=change-moi
# Nombre d'annonces publiées par exécution (défaut 3).
CAMPAIGN_BATCH_SIZE=3

# App
NEXT_PUBLIC_APP_URL=https://annonce.id
